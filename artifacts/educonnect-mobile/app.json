{
  "expo": {
    "name": "EduConnect Haïti",
    "slug": "educonnect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Logo.jpeg",
    "scheme": "educonnect-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#00205B"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.educonnect.haiti"
    },
    "web": {
      "favicon": "./assets/images/Logo.jpeg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
